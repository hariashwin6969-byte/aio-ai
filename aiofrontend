// ── 6. ANTI-GRAVITY INTERFACE ────────────────────────────────────────────────
function AntiGravityModal() {
  const [nodes, setNodes] = useState(() => [
    { id: 1, label: '🧠 Neural', x: 160, y: 80, color: '#00F5FF' },
    { id: 2, label: '📡 IoT', x: 280, y: 130, color: '#7B61FF' },
    { id: 3, label: '⚡ Power', x: 100, y: 170, color: '#FEBC2E' },
    { id: 4, label: '🔐 Secure', x: 230, y: 210, color: '#FF6B6B' },
    { id: 5, label: '☁️ Cloud', x: 310, y: 80, color: '#00FF88' },
  ])
  const [dragging, setDragging] = useState(null)
  const [offset, setOffset] = useState({ x: 0, y: 0 })
  const [active, setActive] = useState(null)
  const svgRef = useRef(null)

  // ── .env config panel state ──────────────────────────────────────────────
  const [tab, setTab] = useState('spatial') // 'spatial' | 'env'
  const [envKey, setEnvKey] = useState('')
  const [envPort, setEnvPort] = useState('5001')
  const [showKey, setShowKey] = useState(false)
  const [envStatus, setEnvStatus] = useState(null) // null | 'saving' | 'ok' | 'error'

  const saveEnv = async () => {
    if (!envKey.trim()) return
    setEnvStatus('saving')
    try {
      const res = await fetch('/api/env', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ GEMINI_API_KEY: envKey.trim(), PORT: envPort }),
      })
      if (!res.ok) throw new Error('server')
      setEnvStatus('ok')
    } catch {
      // fallback: copy to clipboard
      navigator.clipboard.writeText(`GEMINI_API_KEY=${envKey.trim()}\nPORT=${envPort}`)
      setEnvStatus('copied')
    }
    setTimeout(() => setEnvStatus(null), 3000)
  }

  const onMouseDown = (e, id) => {
    e.preventDefault()
    const rect = svgRef.current.getBoundingClientRect()
    const node = nodes.find(n => n.id === id)
    setDragging(id)
    setActive(id)
    setOffset({ x: e.clientX - rect.left - node.x, y: e.clientY - rect.top - node.y })
  }

  const onMouseMove = useCallback((e) => {
    if (!dragging || !svgRef.current) return
    const rect = svgRef.current.getBoundingClientRect()
    const x = Math.max(30, Math.min(370, e.clientX - rect.left - offset.x))
    const y = Math.max(30, Math.min(250, e.clientY - rect.top - offset.y))
    setNodes(ns => ns.map(n => n.id === dragging ? { ...n, x, y } : n))
  }, [dragging, offset])

  const onMouseUp = () => setDragging(null)

  useEffect(() => {
    window.addEventListener('mousemove', onMouseMove)
    window.addEventListener('mouseup', onMouseUp)
    return () => { window.removeEventListener('mousemove', onMouseMove); window.removeEventListener('mouseup', onMouseUp) }
  }, [onMouseMove])

  const connections = []
  for (let i = 0; i < nodes.length; i++)
    for (let j = i + 1; j < nodes.length; j++)
      connections.push([nodes[i], nodes[j]])

  const statusColor = { ok: '#00FF88', error: '#FF6B6B', copied: '#00F5FF', saving: '#7B61FF' }
  const statusLabel = { ok: '✓ SAVED TO .env', error: '✗ SAVE FAILED', copied: '📋 COPIED TO CLIPBOARD', saving: '⟳ SAVING...' }

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>

      {/* Tab switcher */}
      <div style={{ display: 'flex', gap: 6, background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: 4 }}>
        {[{ id: 'spatial', label: '🚀 Spatial UI' }, { id: 'env', label: '⚙️ .env Config' }].map(t => (
          <button key={t.id} onClick={() => setTab(t.id)}
            style={{
              flex: 1, padding: '8px 0', border: 'none', borderRadius: 7, cursor: 'pointer', fontFamily: 'Orbitron,monospace', fontSize: 9, letterSpacing: 1.5,
              background: tab === t.id ? 'rgba(0,245,255,0.12)' : 'transparent',
              color: tab === t.id ? '#00F5FF' : 'rgba(255,255,255,0.35)',
              borderBottom: tab === t.id ? '1.5px solid #00F5FF' : '1.5px solid transparent',
              transition: 'all 0.2s'
            }}>
            {t.label}
          </button>
        ))}
      </div>

      {/* ── Spatial tab ── */}
      {tab === 'spatial' && (
        <>
          <div style={{ fontFamily: 'Orbitron,monospace', fontSize: 9, letterSpacing: 3, color: 'rgba(0,245,255,0.5)', textAlign: 'center' }}>
            SPATIAL INTERFACE — DRAG NODES TO RECONFIGURE
          </div>
          <svg ref={svgRef} width="100%" viewBox="0 0 400 280"
            style={{ background: 'rgba(0,0,0,0.3)', border: '0.5px solid rgba(0,245,255,0.1)', borderRadius: 14, cursor: dragging ? 'grabbing' : 'default', userSelect: 'none' }}>
            {Array.from({ length: 10 }, (_, i) => (
              <line key={`v${i}`} x1={i * 44} y1={0} x2={i * 44} y2={280} stroke="rgba(0,245,255,0.04)" strokeWidth={0.5} />
            ))}
            {Array.from({ length: 7 }, (_, i) => (
              <line key={`h${i}`} x1={0} y1={i * 44} x2={400} y2={i * 44} stroke="rgba(0,245,255,0.04)" strokeWidth={0.5} />
            ))}
            {connections.map(([a, b], i) => {
              const dist = Math.hypot(b.x - a.x, b.y - a.y)
              const alpha = Math.max(0, 1 - dist / 260)
              return (
                <line key={i} x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                  stroke={`rgba(0,245,255,${(alpha * 0.4).toFixed(2)})`} strokeWidth={alpha > 0.3 ? 1 : 0.3} />
              )
            })}
            {nodes.map(n => (
              <g key={n.id} transform={`translate(${n.x},${n.y})`}
                onMouseDown={e => onMouseDown(e, n.id)} style={{ cursor: 'grab' }}>
                {active === n.id && <circle r={28} fill={`${n.color}18`} />}
                <circle r={18} fill={`${n.color}22`} stroke={n.color} strokeWidth={active === n.id ? 1.5 : 0.8} />
                <circle r={5} fill={n.color} />
                <foreignObject x={-30} y={22} width={60} height={20}>
                  <div style={{ fontSize: 9, color: n.color, fontFamily: 'Orbitron,monospace', textAlign: 'center', letterSpacing: 0.5, whiteSpace: 'nowrap' }}>{n.label}</div>
                </foreignObject>
              </g>
            ))}
          </svg>
          <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
            {nodes.map(n => (
              <div key={n.id} style={{ fontSize: 10, padding: '4px 10px', borderRadius: 20, background: `${n.color}18`, border: `0.5px solid ${n.color}66`, color: n.color, fontFamily: 'Orbitron,monospace', letterSpacing: 0.5 }}>
                {n.label} · {Math.round(n.x)},{Math.round(n.y)}
              </div>
            ))}
          </div>
          <div style={{ fontSize: 11, color: 'rgba(255,255,255,0.3)', textAlign: 'center' }}>
            3D spatial UI · Drag nodes · Connection strength = proximity
          </div>
        </>
      )}

      {/* ── .env Config tab ── */}
      {tab === 'env' && (
        <div style={{ display: 'flex', flexDirection: 'column', gap: 14 }}>
          <div style={{ background: 'rgba(0,0,0,0.35)', border: '0.5px solid rgba(0,245,255,0.15)', borderRadius: 12, padding: '14px 16px' }}>
            <div style={{ fontSize: 9, fontFamily: 'Orbitron,monospace', letterSpacing: 2, color: 'rgba(0,245,255,0.5)', marginBottom: 10 }}>// .env CONFIGURATION</div>

            {/* API Key field */}
            <div style={{ marginBottom: 12 }}>
              <div style={{ fontSize: 10, color: 'rgba(255,255,255,0.4)', fontFamily: 'monospace', marginBottom: 6 }}>GEMINI_API_KEY</div>
              <div style={{ display: 'flex', gap: 8 }}>
                <input
                  type={showKey ? 'text' : 'password'}
                  value={envKey}
                  onChange={e => setEnvKey(e.target.value)}
                  placeholder="AIzaSy..."
                  style={{ flex: 1, background: 'rgba(255,255,255,0.04)', border: '0.5px solid rgba(0,245,255,0.2)', borderRadius: 8, padding: '10px 12px', color: '#00F5FF', fontFamily: 'monospace', fontSize: 12, outline: 'none', letterSpacing: showKey ? 0 : 2 }}
                />
                <button onClick={() => setShowKey(v => !v)}
                  style={{ padding: '0 12px', background: 'rgba(255,255,255,0.04)', border: '0.5px solid rgba(255,255,255,0.1)', borderRadius: 8, color: 'rgba(255,255,255,0.5)', cursor: 'pointer', fontSize: 14 }}>
                  {showKey ? '🙈' : '👁'}
                </button>
              </div>
            </div>

            {/* PORT field */}
            <div style={{ marginBottom: 16 }}>
              <div style={{ fontSize: 10, color: 'rgba(255,255,255,0.4)', fontFamily: 'monospace', marginBottom: 6 }}>PORT</div>
              <input
                type="text"
                value={envPort}
                onChange={e => setEnvPort(e.target.value)}
                style={{ width: '100%', background: 'rgba(255,255,255,0.04)', border: '0.5px solid rgba(123,97,255,0.2)', borderRadius: 8, padding: '10px 12px', color: '#7B61FF', fontFamily: 'monospace', fontSize: 12, outline: 'none' }}
              />
            </div>

            {/* Preview */}
            <div style={{ background: 'rgba(0,0,0,0.4)', border: '0.5px solid rgba(255,255,255,0.06)', borderRadius: 8, padding: '10px 14px', fontFamily: 'monospace', fontSize: 11, lineHeight: 1.8, marginBottom: 14 }}>
              <span style={{ color: 'rgba(255,255,255,0.25)' }}># .env preview</span><br />
              <span style={{ color: '#00F5FF' }}>GEMINI_API_KEY</span>
              <span style={{ color: 'rgba(255,255,255,0.4)' }}>=</span>
              <span style={{ color: '#00FF88' }}>{envKey ? (showKey ? envKey : 'AIzaSy' + '•'.repeat(Math.max(0, envKey.length - 6))) : '<your-key>'}</span><br />
              <span style={{ color: '#00F5FF' }}>PORT</span>
              <span style={{ color: 'rgba(255,255,255,0.4)' }}>=</span>
              <span style={{ color: '#FEBC2E' }}>{envPort}</span>
            </div>

            {/* Actions */}
            <div style={{ display: 'flex', gap: 8 }}>
              <motion.button whileTap={{ scale: 0.96 }} onClick={saveEnv} disabled={!envKey.trim() || envStatus === 'saving'}
                style={{ flex: 2, background: envKey.trim() ? 'linear-gradient(135deg,#00F5FF,#7B61FF)' : 'rgba(255,255,255,0.05)', color: envKey.trim() ? '#0B0F1A' : 'rgba(255,255,255,0.2)', border: 'none', padding: '11px', borderRadius: 9, fontFamily: 'Poppins,sans-serif', fontSize: 13, fontWeight: 600, cursor: envKey.trim() ? 'pointer' : 'not-allowed', transition: 'all 0.2s' }}>
                {envStatus === 'saving' ? 'Saving...' : '💾 Save & Apply'}
              </motion.button>
              <motion.button whileTap={{ scale: 0.96 }} onClick={() => { navigator.clipboard.writeText(`GEMINI_API_KEY=${envKey}\nPORT=${envPort}`); setEnvStatus('copied'); setTimeout(() => setEnvStatus(null), 2500) }}
                style={{ flex: 1, background: 'rgba(255,255,255,0.04)', border: '0.5px solid rgba(255,255,255,0.1)', padding: '11px', borderRadius: 9, color: 'rgba(255,255,255,0.5)', fontFamily: 'Poppins,sans-serif', fontSize: 13, cursor: 'pointer' }}>
                📋 Copy
