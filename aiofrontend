import { useState, useRef } from 'react'
import { motion, useInView } from 'framer-motion'

const MODES = [
  {
    id: 'generate',
    label: '⚡ Generate Response',
    system: 'You are AIO AI, a futuristic combined intelligence system with anti-gravity technology. Respond in character — confident, technical, slightly futuristic. Keep responses to 3-4 sentences.',
  },
  {
    id: 'summarize',
    label: '📋 Summarize',
    system: "You are AIO AI's summarization engine. Extract the key essence of anything the user provides in 2-3 crisp bullet points. If no text is provided, ask them to paste something to summarize.",
  },
  {
    id: 'notes',
    label: '📝 Create Notes',
    system: "You are AIO AI's smart notes system. Convert the user's input into structured smart notes with a title, key points, and one action item. Format it cleanly.",
  },
]

// Using backend Gemini API proxy at /api/chat

export default function Demo() {
  const [input, setInput] = useState('')
  const [output, setOutput] = useState('')
  const [loading, setLoading] = useState(false)
  const [mode, setMode] = useState('generate')
  const [error, setError] = useState('')
  const ref = useRef(null)
  const inView = useInView(ref, { once: true, margin: '-80px' })

  const activeMode = MODES.find(m => m.id === mode)

  const run = async () => {
    if (!input.trim()) return
    setLoading(true)
    setOutput('')
    setError('')

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          system: activeMode.system,
          messages: [{ role: 'user', content: input }],
        }),
      })

      const data = await res.json()

      if (!res.ok) {
        throw new Error(data?.error?.message || `API error ${res.status}`)
      }

      const text =
        data.content?.map(c => c.text || '').join('') ||
        'No response received.'
      setOutput(text)
    } catch (e) {
      setError(e.message || 'Connection error. Check your API key.')
    } finally {
      setLoading(false)
    }
  }

  return (
    <section id="demo" ref={ref} style={{ padding: '100px 40px', maxWidth: 820, margin: '0 auto' }}>
      <motion.div initial={{ opacity: 0, y: 20 }} animate={inView ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.6 }}>
        <div style={{ fontFamily: 'Orbitron, monospace', fontSize: 10, letterSpacing: 4, color: '#7B61FF', marginBottom: 12 }}>// INTERACTIVE DEMO</div>
        <h2 style={{ fontFamily: 'Orbitron, monospace', fontSize: 'clamp(24px,3vw,40px)', fontWeight: 700, marginBottom: 14 }}>
          Ask <span style={{ color: '#7B61FF' }}>AIO AI</span>
        </h2>
        <p style={{ fontSize: 15, color: 'rgba(255,255,255,0.45)', maxWidth: 460, lineHeight: 1.7, marginBottom: 48, fontWeight: 300 }}>
          Powered by real AI. Type anything and experience live intelligence.
        </p>
      </motion.div>

      <motion.div
        initial={{ opacity: 0, y: 30 }}
        animate={inView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.6, delay: 0.2 }}
        style={{ background: 'rgba(255,255,255,0.02)', border: '0.5px solid rgba(123,97,255,0.2)', borderRadius: 20, padding: 36 }}
      >
        {/* Terminal header */}
        <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 28 }}>
          {['#FF5F57', '#FEBC2E', '#28C840'].map(c => (
            <div key={c} style={{ width: 10, height: 10, borderRadius: '50%', background: c }} />
          ))}
          <span style={{ fontFamily: 'Orbitron, monospace', fontSize: 10, color: 'rgba(255,255,255,0.25)', marginLeft: 8, letterSpacing: 2 }}>
            AIO TERMINAL v2.0 — LIVE AI
          </span>
          <span style={{ marginLeft: 'auto', fontSize: 10, fontFamily: 'Orbitron, monospace', color: '#00F5FF', animation: 'pulse 1.5s ease infinite' }}>
            ● ONLINE
          </span>
        </div>

        {/* Mode selector */}
        <div style={{ display: 'flex', gap: 10, flexWrap: 'wrap', marginBottom: 20 }}>
          {MODES.map(m => (
            <motion.button
              key={m.id}
              whileTap={{ scale: 0.96 }}
              onClick={() => setMode(m.id)}
              style={{
                background: mode === m.id ? 'rgba(0,245,255,0.1)' : 'rgba(123,97,255,0.08)',
                border: `0.5px solid ${mode === m.id ? 'rgba(0,245,255,0.4)' : 'rgba(123,97,255,0.25)'}`,
                color: mode === m.id ? '#00F5FF' : '#7B61FF',
                padding: '9px 18px', borderRadius: 8,
                fontFamily: 'Poppins, sans-serif', fontSize: 13,
                cursor: 'pointer', transition: 'all 0.2s',
              }}
            >
              {m.label}
            </motion.button>
          ))}
        </div>

        {/* Input */}
        <div style={{ display: 'flex', gap: 10, marginBottom: 16 }}>
          <input
            value={input}
            onChange={e => setInput(e.target.value)}
            onKeyDown={e => e.key === 'Enter' && run()}
            placeholder="Ask AI anything... (press Enter)"
            style={{
              flex: 1, background: 'rgba(255,255,255,0.04)',
              border: '0.5px solid rgba(255,255,255,0.1)',
              borderRadius: 10, padding: '14px 18px',
              color: '#fff', fontFamily: 'Poppins, sans-serif', fontSize: 14,
              outline: 'none',
            }}
          />
          <motion.button
            whileTap={{ scale: 0.96 }}
            onClick={run}
            disabled={loading || !input.trim()}
            style={{
              background: loading ? 'rgba(0,245,255,0.3)' : 'linear-gradient(135deg, #00F5FF, #7B61FF)',
              color: '#0B0F1A', border: 'none', padding: '12px 22px',
              borderRadius: 10, fontFamily: 'Poppins, sans-serif',
              fontSize: 14, fontWeight: 600, cursor: loading ? 'not-allowed' : 'pointer',
              whiteSpace: 'nowrap',
            }}
          >
            {loading ? '...' : 'Send'}
          </motion.button>
        </div>

        {/* Output */}
        <div style={{
          background: 'rgba(0,0,0,0.3)',
          border: '0.5px solid rgba(0,245,255,0.08)',
          borderRadius: 12, padding: 22, minHeight: 100,
        }}>
          {loading && (
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              <div style={{ display: 'flex', gap: 4 }}>
                {[0, 1, 2].map(i => (
                  <motion.div
                    key={i}
                    animate={{ opacity: [0.3, 1, 0.3] }}
                    transition={{ duration: 0.8, delay: i * 0.15, repeat: Infinity }}
                    style={{ width: 6, height: 6, borderRadius: '50%', background: '#00F5FF' }}
                  />
                ))}
              </div>
              <span style={{ fontSize: 12, fontFamily: 'Orbitron, monospace', color: 'rgba(0,245,255,0.6)', letterSpacing: 2 }}>
                AIO THINKING...
              </span>
            </div>
          )}
          {error && <div style={{ color: '#FF6B6B', fontSize: 13 }}>{error}</div>}
          {!loading && !error && output && (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              transition={{ duration: 0.4 }}
              style={{ fontSize: 14, color: 'rgba(255,255,255,0.75)', lineHeight: 1.8, fontWeight: 300, whiteSpace: 'pre-wrap' }}
            >
              {output}
            </motion.div>
          )}
          {!loading && !error && !output && (
            <span style={{ color: 'rgba(255,255,255,0.2)', fontSize: 13, fontStyle: 'italic' }}>
              Your AI response will appear here...
            </span>
          )}
        </div>
      </motion.div>
      <style>{`@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}`}</style>
    </section>
  )
}


